# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Twilio (SMS + Voice)
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_MESSAGING_SERVICE_SID=your-messaging-service-sid

# OpenRouter (AI)
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key

# Stripe (Payments)
STRIPE_SECRET_KEY=sk_live_your-stripe-secret
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# Google OAuth (Calendar)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Resend (Transactional Email for Feedback/GDPR)
RESEND_API_KEY=re_your-resend-api-key
FEEDBACK_EMAIL_TO=you@example.com
FEEDBACK_EMAIL_FROM=feedback@aurabooking.com
GDPR_EMAIL_TO=you@example.com
GDPR_EMAIL_FROM=gdpr@aurabooking.com

# Sentry (Error Monitoring)
SENTRY_DSN=https://your-dsn@sentry.io/your-project

# Twilio 10DLC Compliance — must be public HTTPS pages with 200 OK
PRIVACY_POLICY_URL=https://aurabooking.vercel.app/privacy
TERMS_URL=https://aurabooking.vercel.app/terms

# App
NEXT_PUBLIC_APP_URL=https://aurabooking.vercel.app
SHORT_DOMAIN=aurabooking.co

# Admin Auth (email of the user who gets admin/operator-level access)
ADMIN_EMAIL=you@example.com

# Cron Auth (shared secret for Vercel Cron Jobs)
CRON_SECRET=your-random-cron-secret
